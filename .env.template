# gen-gec-errant (public) — copy to .env and fill; .env is gitignored forever.
#   cp .env.template .env && $EDITOR .env
# Every value below is read by the notebook via env var > .env > Colab userdata > default
# (see src/gen_gec_errant/nbenv.py). A required-but-unset key fails loud, naming itself.

# ── acquisition backend (Cell 4 CONFIG / Cell 4b BROKER) ──
GGE_BROKER=gdrive                 # gdrive | rclone | fserve | local | hf

# rclone broker: a remote that mirrors your Drive + a conf delivered at runtime
GGE_RCLONE_REMOTE=                # e.g. myremote:   (required only when GGE_BROKER=rclone)
GGE_RCLONE_CONF_PATH=             # path to an rclone.conf fetched at runtime (NEVER commit it)

# fserve broker: authenticated curl against your fserve droplet
GGE_FSERVE_BASE_URL=             # e.g. https://DROPLET_IP:47824   (required when GGE_BROKER=fserve)
GGE_FSERVE_USER=colab            # fserve basic-auth user
GGE_FSERVE_PASSCODE=             # fserve passcode — prefer Colab userdata over .env

# ── Drive INPUT layout overrides (optional; defaults = standard Colab MyDrive layout) ──
GGE_DRIVE_MODELS_ROOT=           # e.g. /content/drive/MyDrive/<you>/models
GGE_DRIVE_DATA_ROOT=             # e.g. /content/drive/MyDrive/<you>/data/splits

# ── OUTPUT destination ──
GGE_OUTPUT_ROOT=                 # where ALL results land; default = /content/drive/MyDrive/gen-gec-two-signal-outputs (Colab)
GGE_OUTPUT_BROKER=gdrive         # gdrive | rclone | fserve | local  (where to PUBLISH results; independent of input broker)
GGE_OUTPUT_RCLONE_DEST=          # required when GGE_OUTPUT_BROKER=rclone: a durable remote:path, e.g. myS3:bucket/gge-results
